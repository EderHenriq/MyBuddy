# ── PostgreSQL ───────────────────────────────────────────────
POSTGRES_DB=mybuddy
POSTGRES_USER=mybuddy_prod
POSTGRES_PASSWORD=<GERAR_COM_openssl_rand>
POSTGRES_PORT=5432

# ── MongoDB ──────────────────────────────────────────────────
MONGO_INITDB_ROOT_USERNAME=admin_prod
MONGO_INITDB_ROOT_PASSWORD=<GERAR_COM_openssl_rand>
MONGO_INITDB_DATABASE=mybuddy
MONGO_PORT=27017

# ── Keycloak ─────────────────────────────────────────────────
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=<GERAR_COM_openssl_rand>
KEYCLOAK_DB=keycloak
KEYCLOAK_PORT=8080

# ── Backend ──────────────────────────────────────────────────
SPRING_DATASOURCE_URL=jdbc:postgresql://postgres:5432/mybuddy
SPRING_DATASOURCE_USERNAME=mybuddy_prod
SPRING_DATASOURCE_PASSWORD=<MESMO_QUE_POSTGRES_PASSWORD>
MONGODB_URI=mongodb://admin_prod:<MESMO_QUE_MONGO_PASSWORD>@mongodb:27017
MONGODB_DATABASE=mybuddy
KC_CLIENT_SECRET=<PEGAR_DO_KEYCLOAK_ADMIN_CONSOLE>
JWT_SECRET=<GERAR_COM_openssl_rand_64>
JWT_EXPIRATION_MS=86400000
UPLOAD_DIR=/app/uploads
CORS_ALLOWED_ORIGINS=https://SEU_DOMINIO_AQUI

# ── Mercado Pago ─────────────────────────────────────────────
MERCADOPAGO_ACCESS_TOKEN=<TOKEN_DE_PRODUCAO>
MERCADOPAGO_WEBHOOK_SECRET=<SECRET_DO_WEBHOOK>

# ── Frontend ─────────────────────────────────────────────────
FRONTEND_PORT=80