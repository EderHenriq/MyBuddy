# ── MongoDB ──────────────────────────────────────────────────
MONGO_INITDB_ROOT_USERNAME=admin
MONGO_INITDB_ROOT_PASSWORD=admin
MONGO_INITDB_DATABASE=mybuddy
MONGO_PORT=27017

# ── PostgreSQL ───────────────────────────────────────────────
POSTGRES_DB=mybuddy
POSTGRES_USER=mybuddy
POSTGRES_PASSWORD=mybuddy
POSTGRES_PORT=5432

# ── Keycloak ─────────────────────────────────────────────────
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=admin
KEYCLOAK_DB=keycloak
KEYCLOAK_PORT=8080

# ── Backend ──────────────────────────────────────────────────
SPRING_DATASOURCE_URL=jdbc:postgresql://postgres:5432/mybuddy
SPRING_DATASOURCE_USERNAME=mybuddy
SPRING_DATASOURCE_PASSWORD=mybuddy
MONGODB_URI=mongodb://admin:admin@mongodb:27017
MONGODB_DATABASE=mybuddy
KC_CLIENT_SECRET=your_keycloak_client_secret
JWT_SECRET=your_jwt_secret_min_64_chars
JWT_EXPIRATION_MS=86400000
UPLOAD_DIR=/app/uploads

# ── Frontend ─────────────────────────────────────────────────
FRONTEND_PORT=80
